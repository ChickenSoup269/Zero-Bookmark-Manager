{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.2.3",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "permissions": [
    "bookmarks",
    "storage",
    "sidePanel",
    "tabs",
    "system.display",
    "webNavigation"
  ],
  "action": {},
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "icons": {
    "128": "icons/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "fonts/*.ttf",
        "fonts/*.woff2",
        "images/*.png",
        "images/*.jpg",
        "bookmarks.html",
        "components/sidepanel/sidepanel.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
